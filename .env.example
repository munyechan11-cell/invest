# ───────────────────────────────────────────
# 필수 — 분석 엔진 (현재 코드는 Gemini 사용)
# ───────────────────────────────────────────
# Google Gemini (https://aistudio.google.com/apikey) — 무료 티어 가능
GEMINI_API_KEY=

# Anthropic Claude (사용 시) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ───────────────────────────────────────────
# 보안 (운영 시 반드시 설정)
# ───────────────────────────────────────────
# JWT 시크릿 키 — 비우면 서버 재시작마다 세션이 초기화됨
# 생성 예: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# 관리자 계정 자동 생성용 (비우면 관리자 미생성)
ADMIN_USERNAME=munyechan11
ADMIN_PASSWORD=

# 서버 호스트/포트
HOST=127.0.0.1
PORT=8000

# ───────────────────────────────────────────
# 미국주식 — Alpaca + Finnhub
# ───────────────────────────────────────────
# Alpaca Paper Trading (https://alpaca.markets) — 캔들·지표용 (무료)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Finnhub (https://finnhub.io) — 미국 실시간 quote, 뉴스, 인사이더 (무료 60req/min)
FINNHUB_API_KEY=

# ───────────────────────────────────────────
# 한국주식 — KIS + Naver + DART
# ───────────────────────────────────────────
# 한국투자증권 KIS Open API (https://apiportal.koreainvestment.com)
# 실시간 KOSPI/KOSDAQ + 외국인/기관/개인 수급. 무료.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_PAPER=true                  # 모의투자 환경 사용 (실전은 false)

# 네이버 검색 API (https://developers.naver.com) — 한국 뉴스. 무료 25,000req/일
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# DART 전자공시 (https://opendart.fss.or.kr) — 한국 공시. 무료
DART_API_KEY=

# ───────────────────────────────────────────
# 옵션
# ───────────────────────────────────────────
# Telegram 봇 (모바일 알림 백업) — @BotFather에서 발급
TELEGRAM_BOT_TOKEN=

# 자동 주문 (페이퍼만 권장)
AUTO_TRADE_ENABLED=false
